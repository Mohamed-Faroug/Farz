{
  "expo": {
    "name": "Farz",
    "slug": "farz",
    "version": "1.4.0",
    "description": "Swipe through your photos to keep or trash them — fast, fun gallery cleanup.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "farz",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#bdf14d",
    "newArchEnabled": true,
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#fc6f1f"  //1a1a2e
      },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.farz.app",
      "supportsRTL": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Farz needs access to your photos so you can review and clean your gallery.",
        "NSPhotoLibraryAddUsageDescription": "Farz may need access to save changes when you delete photos from your gallery."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fc6f1f"    // 1a1a2e
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.farz.app",
      "supportsRTL": true,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Farz to access your photos to help you clean your gallery.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6d40d359-2d3b-406b-b131-ac2dcdeee5a9"
      }
    }
  }
}
